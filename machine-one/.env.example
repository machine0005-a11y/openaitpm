# ====== REQUIRED ======

# Anthropic — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Twilio — get from https://console.twilio.com (Account SID + Auth Token)
# Your phone number is already +19495089229 — confirm it's owned by this account
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+19495089229

# Public URL where this server is reachable from the internet.
# - Production: https://openaitpm.com
# - Local dev:  whatever ngrok / cloudflared gives you (https://abc123.ngrok.io)
PUBLIC_BASE_URL=https://openaitpm.com

# ====== OPTIONAL ======

# Gmail notifications. Use an *App Password*, not your real password.
# Generate one at https://myaccount.google.com/apppasswords
# (2FA must be enabled on machine005@gmail.com first.)
GMAIL_USER=machine005@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_NOTIFY_TO=machine005@gmail.com

# Port (default 3000)
PORT=3000

# Claude model — defaults to the latest Sonnet for speed/cost,
# bump to claude-opus-4-7 if you want maximum quality prototypes
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
